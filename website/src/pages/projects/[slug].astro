---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Icon from '../../components/Icon.astro';
import Footer from '../../components/Footer.astro';
import { projects, type Project } from '../../data/projects';
import { techIconMap } from '../../utils/techIcons';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<Layout title={`${project.title} — Hayden Huan`}>
  <Navbar />
  <main class="max-w-3xl mx-auto px-6 md:px-12 pb-24 pt-12 md:pt-20">
    <article class="fade-in-up">
      <a
        href="/"
        class="flex items-center gap-2 text-stone-500 hover:text-stone-900 transition-colors mb-12 text-sm font-medium"
      >
        <Icon name="arrow-left" size={16} /> Previous Page
      </a>

      <div class="mb-12">
        <h1 class="text-4xl md:text-5xl font-heading font-semibold text-stone-900 mb-4 leading-[1.1]">
          {project.title}
        </h1>
        {project.inProgress && (
          <span class="inline-flex items-center gap-1.5 px-3 py-1 mb-6 bg-amber-100 text-amber-700 text-xs font-semibold rounded-full border border-amber-200 uppercase tracking-wide">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse"></span>
            In Progress
          </span>
        )}
        <div class="flex flex-wrap gap-2 mb-8">
          {project.tech.map((t) => {
            const iconClass = techIconMap[t];
            return (
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-stone-100 text-stone-700 text-sm rounded-md font-medium border border-stone-200">
                {iconClass && <i class={`${iconClass} text-base leading-none`}></i>}
                {t}
              </span>
            );
          })}
        </div>
        <p class="text-xl text-stone-600 font-light leading-relaxed">
          {project.description}
        </p>
      </div>

      <div class="mb-16">
        {project.content.map((paragraph) => (
          <p class="text-stone-700 leading-relaxed mb-6 font-light text-lg">{paragraph}</p>
        ))}
      </div>

      {project.slug === 'finguardmy' && (
        <div class="mb-16">
          <h3 class="font-heading font-semibold text-lg text-stone-900 mb-4">System Architecture</h3>
          <img
            src="/Architecture.svg"
            alt="FinGuardMY system architecture diagram"
            class="w-full rounded-xl border border-stone-200"
          />
        </div>
      )}

      <div class="p-8 bg-stone-100 rounded-xl border border-stone-200">
        <h3 class="font-heading font-semibold text-lg mb-4 text-stone-900">
          Key Architectural Highlights
        </h3>
        <ul class="space-y-4">
          {project.highlights.map((highlight) => (
            <li class="flex gap-4 text-stone-700">
              <span class="text-stone-400 mt-1">▹</span>
              <span class="leading-relaxed">{highlight}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="mt-16 pt-8 border-t border-stone-200 flex justify-center">
        <a
          href="/"
          class="px-6 py-3 bg-stone-900 text-stone-50 rounded-md hover:bg-stone-800 transition-colors font-medium text-sm"
        >
          Return to Portfolio
        </a>
      </div>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  .fade-in-up {
    animation: fadeInUp 0.5s ease-out;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(1rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

</style>

