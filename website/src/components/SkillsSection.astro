---
import Icon from './Icon.astro';
import SectionHeader from './SectionHeader.astro';
import { techIconMap } from '../utils/techIcons';

const categories = [
  {
    title: 'Backend & APIs',
    icon: 'server' as const,
    skills: ['Java (Spring Boot)', 'Python', 'FastAPI'],
  },
  {
    title: 'Infrastructure',
    icon: 'layers' as const,
    skills: ['Kubernetes', 'Docker', 'Nginx', 'Caddy'],
  },
  {
    title: 'Data & Events',
    icon: 'share2' as const,
    skills: ['Apache Kafka', 'Apache Airflow', 'Apache Spark', 'Valkey'],
  },
  {
    title: 'Databases',
    icon: 'database' as const,
    skills: ['PostgreSQL', 'MySQL', 'Redis', 'Pinecone'],
  },
];
---

<section id="skills" class="py-24 border-t border-stone-200">
  <SectionHeader title="Tech Skills" subtitle="Core competencies and technologies." />

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-12">
    {categories.map((cat) => (
      <div class="p-8 border border-stone-200 rounded-xl bg-white hover:border-stone-300 hover:shadow-sm transition-all">
        <div class="flex items-center gap-3 mb-6">
          <div class="p-3 bg-stone-100 rounded-lg">
            <Icon name={cat.icon} size={20} class="text-stone-700" />
          </div>
          <h3 class="font-heading font-semibold text-lg">{cat.title}</h3>
        </div>
        <div class="flex flex-wrap gap-2">
          {cat.skills.map((skill) => {
            const iconClass = techIconMap[skill];
            return (
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-stone-100 text-stone-700 text-sm rounded-md font-medium">
                {iconClass && <i class={`${iconClass} text-base leading-none`}></i>}
                {skill}
              </span>
            );
          })}
        </div>
      </div>
    ))}
  </div>
</section>
