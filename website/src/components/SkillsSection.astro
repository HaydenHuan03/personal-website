---
import Icon from './Icon.astro';
import SectionHeader from './SectionHeader.astro';

const categories = [
  {
    title: 'Backend & APIs',
    icon: 'server' as const,
    skills: ['Java (Spring Boot)', 'Kotlin', 'Python', 'FastAPI', 'REST & gRPC'],
  },
  {
    title: 'Infrastructure',
    icon: 'layers' as const,
    skills: ['Kubernetes', 'Docker', 'Nginx', 'Caddy', 'CI/CD Pipelines'],
  },
  {
    title: 'Data & Events',
    icon: 'share2' as const,
    skills: ['Apache Kafka', 'Apache Airflow', 'Apache Spark', 'Valkey', 'Event-Driven Arch.'],
  },
  {
    title: 'Databases',
    icon: 'database' as const,
    skills: ['PostgreSQL', 'MySQL', 'Vector Databases', 'Redis', 'Hybrid SQL'],
  },
];
---

<section id="skills" class="py-24 border-t border-stone-200">
  <SectionHeader title="The Arsenal" subtitle="Core competencies and technologies." />

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-12">
    {categories.map((cat) => (
      <div class="p-8 border border-stone-200 rounded-xl bg-white hover:border-stone-300 hover:shadow-sm transition-all">
        <div class="flex items-center gap-3 mb-6">
          <div class="p-3 bg-stone-100 rounded-lg">
            <Icon name={cat.icon} size={20} class="text-stone-700" />
          </div>
          <h3 class="font-heading font-semibold text-lg">{cat.title}</h3>
        </div>
        <div class="flex flex-wrap gap-2">
          {cat.skills.map((skill) => (
            <span class="px-3 py-1 bg-stone-100 text-stone-700 text-sm rounded-md font-medium">
              {skill}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
