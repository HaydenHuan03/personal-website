---
import Icon from './Icon.astro';
import SectionHeader from './SectionHeader.astro';
import { projects } from '../data/projects';
---

<section id="projects" class="py-24 border-t border-stone-200">
  <SectionHeader title="Selected Work" subtitle="Architectural highlights and engineering challenges." />

  <div class="space-y-4 mt-12">
    {projects.map((project) => (
      <a
        href={`/projects/${project.slug}`}
        class="group flex flex-col md:flex-row gap-8 items-start p-8 rounded-xl cursor-pointer bg-white border border-stone-200 hover:border-stone-300 hover:shadow-sm transition-all no-underline"
      >
        <div class="md:w-1/3 flex-shrink-0">
          <h3 class="font-heading font-semibold text-xl mb-3 group-hover:text-stone-900 text-stone-800">
            {project.title}
          </h3>
          <div class="flex flex-wrap gap-2 mb-4">
            {project.tech.map((t) => (
              <span class="text-xs font-semibold tracking-wide uppercase text-stone-500">
                {t}
              </span>
            ))}
          </div>
        </div>

        <div class="md:w-2/3">
          <p class="text-stone-600 mb-4 font-light leading-relaxed">
            {project.description}
          </p>
          <div class="flex items-center gap-2 text-sm font-medium text-stone-900 group-hover:text-stone-600 transition-colors mt-6">
            Read full case study
            <Icon name="arrow-right" size={16} class="transform group-hover:translate-x-1 transition-transform" />
          </div>
        </div>
      </a>
    ))}
  </div>
</section>
