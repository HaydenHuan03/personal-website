---
import Icon from './Icon.astro';
---

<section id="about" class="pt-20 pb-32 md:pt-32 md:pb-40 flex flex-col md:flex-row items-center gap-12 md:gap-16">
  <!-- Left: intro text -->
  <div class="flex-1 min-w-0">
    <p class="text-stone-500 font-medium tracking-wide text-sm uppercase mb-4">
      Software Engineer
    </p>
    <h1 class="text-5xl md:text-6xl font-heading font-semibold tracking-tight text-stone-900 mb-6 leading-[1.1]">
      Hayden Huan Kee Jiun
    </h1>
    <p class="text-lg text-stone-600 leading-relaxed font-light mb-10">
      I am a rookie backend developer who enjoys trying new technologies instead of using one tech only. I am passionate about growing my skills and understanding how backend logic connects with reliable infrastructure.
    </p>

    <div class="flex flex-wrap gap-4">
      <a
        href="#projects"
        class="flex items-center gap-2 px-6 py-3 bg-stone-900 text-stone-50 rounded-md hover:bg-stone-800 transition-colors font-medium text-sm"
      >
        View Projects <Icon name="arrow-right" size={16} />
      </a>
      <a
        href="mailto:teomeehua@gmail.com"
        class="flex items-center gap-2 px-6 py-3 border border-stone-300 rounded-md hover:bg-stone-200 transition-colors font-medium text-sm text-stone-900"
      >
        <Icon name="mail" size={16} /> Contact Me
      </a>
      <div class="flex items-center gap-3 ml-2 border-l border-stone-300 pl-6">
        <a href="https://github.com/HaydenHuan03" class="text-stone-500 hover:text-stone-900 transition-colors">
          <Icon name="github" size={20} />
        </a>
      </div>
    </div>
  </div>

  <!-- Right: Profile Picture -->
  <div class="w-full md:w-[380px] md:flex-shrink-0">
    <img
      src="/Profile.webp"
      class="w-full aspect-[3/4] object-cover rounded-2xl ring-1 ring-stone-200 shadow-sm"
    />
  </div>
</section>
